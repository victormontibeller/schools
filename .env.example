# ============================================================
# Application
# ============================================================
SECRET_KEY=change-me-in-production
DEBUG=True
DJANGO_ENV=development
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_NAME=schools_db
DB_TEST_NAME=schools_test_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# RabbitMQ (Celery Broker — NOT Redis)
# ============================================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# ============================================================
# Email
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
DEFAULT_FROM_EMAIL=noreply@schools.example.com